---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found — AQAR Property Management</title>
    <meta name="description" content="The page you are looking for does not exist. Return to AQAR Property Management." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-surface text-neutral-800 font-body min-h-screen flex flex-col items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <p class="text-8xl font-display font-extrabold text-primary-600">404</p>
      <h1 class="mt-4 font-display text-3xl font-bold text-charcoal">Page Not Found</h1>
      <p class="mt-4 text-lg text-neutral-600 leading-relaxed">
        The page you are looking for does not exist or has been moved.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/en/"
          class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-8 py-3.5 text-base font-bold text-white shadow-lg hover:bg-primary-700 transition-colors duration-200"
        >
          English Homepage
        </a>
        <a
          href="/fr/"
          class="inline-flex items-center justify-center rounded-lg bg-charcoal px-8 py-3.5 text-base font-bold text-white shadow-lg hover:bg-neutral-700 transition-colors duration-200"
        >
          Page d'accueil en français
        </a>
      </div>
      <div class="mt-8 space-y-2 text-sm text-neutral-500">
        <p>Popular pages:</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/en/features/" class="text-primary-600 hover:text-primary-800 underline">Features</a>
          <a href="/en/demo/" class="text-primary-600 hover:text-primary-800 underline">Try Demo</a>
          <a href="/en/blog/" class="text-primary-600 hover:text-primary-800 underline">Blog</a>
          <a href="/en/contact/" class="text-primary-600 hover:text-primary-800 underline">Contact</a>
        </div>
      </div>
    </div>
  </body>
</html>
