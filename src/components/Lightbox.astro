---
// Lightbox component — no props needed, driven entirely by Alpine.js and custom events
---

<div
  x-data="{ show: false, src: '', alt: '', caption: '' }"
  x-init="
    window.addEventListener('open-lightbox', (e) => {
      src = e.detail.src;
      alt = e.detail.alt || '';
      caption = e.detail.caption || '';
      show = true;
    });
  "
  @keydown.escape.window="show = false"
>
  <!-- Overlay -->
  <template x-teleport="body">
    <div
      x-show="show"
      x-cloak
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-[100] flex items-center justify-center bg-charcoal/90 backdrop-blur-sm p-4"
      @click.self="show = false"
    >
      <!-- Close button -->
      <button
        class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors duration-200 z-10"
        @click="show = false"
        aria-label="Close lightbox"
      >
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Image container -->
      <div class="relative max-w-5xl w-full max-h-[85vh] flex flex-col items-center">
        <img
          :src="src"
          :alt="alt"
          class="max-h-[80vh] w-auto max-w-full rounded-lg shadow-2xl object-contain"
          x-show="show"
          x-transition:enter="transition ease-out duration-300 delay-100"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100"
        />

        <!-- Caption bar -->
        <div
          x-show="caption"
          class="mt-3 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-lg text-white text-sm text-center max-w-lg"
          x-text="caption"
        ></div>
      </div>
    </div>
  </template>
</div>
