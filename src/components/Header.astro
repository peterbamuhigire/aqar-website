---
import type { Language } from '../utils/i18n';
import { getLocalizedPath } from '../utils/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = {
  en: [
    { label: 'Home', page: '' },
    { label: 'Features', page: 'features' },
    { label: 'About', page: 'about' },
    { label: 'Blog', page: 'blog' },
    { label: 'Contact', page: 'contact' },
  ],
  fr: [
    { label: 'Accueil', page: '' },
    { label: 'Fonctionnalit\u00e9s', page: 'features' },
    { label: '\u00c0 propos', page: 'about' },
    { label: 'Blog', page: 'blog' },
    { label: 'Contact', page: 'contact' },
  ],
};

const ctaLabels = {
  en: { demo: 'Try Demo', whatsapp: 'WhatsApp Us' },
  fr: { demo: 'Essayer la D\u00e9mo', whatsapp: 'WhatsApp' },
};

const links = navLinks[lang];
const cta = ctaLabels[lang];

function isActive(page: string): boolean {
  const localizedPath = getLocalizedPath(page, lang);
  if (page === '') {
    return currentPath === localizedPath;
  }
  return currentPath.startsWith(localizedPath);
}

// Derive pageKey from current path for the language switcher
function getPageKey(): string {
  const segments = currentPath.replace(/^\//, '').replace(/\/$/, '').split('/');
  return segments.length > 1 ? segments[1] : '';
}
const pageKey = getPageKey();
---

<header
  class="fixed top-0 inset-x-0 z-50 transition-colors duration-300 bg-charcoal/95 backdrop-blur-lg"
  x-data="{ open: false }"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href={getLocalizedPath('', lang)} class="flex items-center gap-1 text-xl font-display font-extrabold tracking-tight text-white">
        <span class="text-secondary-500">A</span>QAR
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6">
        {links.map((link) => (
          <a
            href={getLocalizedPath(link.page, lang)}
            class:list={[
              'text-sm font-semibold transition-colors duration-200',
              isActive(link.page)
                ? 'text-secondary-400'
                : 'text-neutral-300 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop right side -->
      <div class="hidden md:flex items-center gap-3">
        <LanguageSwitcher currentLang={lang} currentPath={pageKey} />
        <a
          href="https://property.chwezi.co.za"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 transition-colors duration-200"
        >
          {cta.demo}
        </a>
        <a
          href="https://wa.me/256784464178"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg bg-secondary-500 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-secondary-600 transition-colors duration-200"
        >
          {cta.whatsapp}
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-neutral-300 hover:text-white focus:outline-none"
        @click="open = !open"
        :aria-expanded="open"
        aria-label="Toggle navigation"
      >
        <svg x-show="!open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg x-show="open" x-cloak class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    class="md:hidden border-t border-white/10 bg-charcoal/95 backdrop-blur-lg"
  >
    <div class="space-y-1 px-4 pb-4 pt-3">
      {links.map((link) => (
        <a
          href={getLocalizedPath(link.page, lang)}
          class:list={[
            'block rounded-md px-3 py-2 text-base font-semibold transition-colors duration-200',
            isActive(link.page)
              ? 'text-secondary-400 bg-white/5'
              : 'text-neutral-300 hover:text-white hover:bg-white/5',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="flex items-center gap-3 pt-3 border-t border-white/10 mt-3">
        <LanguageSwitcher currentLang={lang} currentPath={pageKey} />
      </div>
      <div class="flex flex-col gap-2 pt-3">
        <a
          href="https://property.chwezi.co.za"
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-lg bg-primary-600 px-4 py-2.5 text-center text-sm font-semibold text-white hover:bg-primary-700 transition-colors duration-200"
        >
          {cta.demo}
        </a>
        <a
          href="https://wa.me/256784464178"
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-lg bg-secondary-500 px-4 py-2.5 text-center text-sm font-semibold text-white hover:bg-secondary-600 transition-colors duration-200"
        >
          {cta.whatsapp}
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>
