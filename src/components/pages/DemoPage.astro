---
import type { Language } from '../../utils/i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Lightbox from '../../components/Lightbox.astro';
import { Image } from 'astro:assets';

import heroBg from '../../assets/images/AQAR-PROPERTY-07.jpg';
import screenshotLogin from '../../assets/images/SCREENSHOT-LOGIN.jpg';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const content = {
  en: {
    title: 'Try AQAR Demo | No Signup Required',
    description: 'Try the AQAR property management demo instantly. No signup, no installation \u2014 just open and explore.',
    heroTitle: 'Try Aqar \u2014 No Signup Required',
    heroSubtitle: 'Experience the full property management platform. No forms, no credit card, no waiting.',
    loginAlt: 'AQAR Login Screen',
    loginCaption: 'The AQAR login screen \u2014 instant access to the demo.',
    featuresTitle: 'What the Demo Includes',
    features: [
      { title: 'Property Portfolio Dashboard', desc: 'View and manage multiple properties with real-time occupancy data.' },
      { title: 'Tenant Management', desc: 'Add tenants, track leases, and manage communications.' },
      { title: 'Rent Collection & Invoicing', desc: 'Generate invoices, record payments, and track arrears.' },
      { title: 'Maintenance Tracking', desc: 'Log maintenance requests and track resolution progress.' },
      { title: 'Financial Reports', desc: 'Income statements, landlord remittances, and expense tracking.' },
      { title: 'Role-Based Access Control', desc: 'Set permissions for staff, landlords, and administrators.' },
    ],
    ctaTitle: 'Ready to Explore?',
    ctaDesc: 'The live demo is pre-loaded with sample data. Click below to start exploring immediately.',
    ctaBtn: 'Open Live Demo',
    ctaNote: 'No installation \u00b7 No signup \u00b7 No credit card',
    questionsTitle: 'Have Questions?',
    questionsDesc: 'Our team is ready to help you understand how Aqar can work for your portfolio.',
    whatsappBtn: 'Chat on WhatsApp',
  },
  fr: {
    title: 'Essayez la D\u00e9mo AQAR | Aucune inscription requise',
    description: 'Essayez la d\u00e9mo de gestion immobili\u00e8re AQAR instantan\u00e9ment. Aucune inscription, aucune installation \u2014 ouvrez et explorez.',
    heroTitle: 'Essayez Aqar \u2014 Aucune inscription requise',
    heroSubtitle: 'D\u00e9couvrez la plateforme compl\u00e8te de gestion immobili\u00e8re. Aucun formulaire, aucune carte de cr\u00e9dit, aucune attente.',
    loginAlt: '\u00c9cran de connexion AQAR',
    loginCaption: 'L\u2019\u00e9cran de connexion AQAR \u2014 acc\u00e8s instantan\u00e9 \u00e0 la d\u00e9mo.',
    featuresTitle: 'Ce que la D\u00e9mo Comprend',
    features: [
      { title: 'Tableau de Bord du Portefeuille', desc: 'Visualisez et g\u00e9rez plusieurs propri\u00e9t\u00e9s avec des donn\u00e9es d\u2019occupation en temps r\u00e9el.' },
      { title: 'Gestion des Locataires', desc: 'Ajoutez des locataires, suivez les baux et g\u00e9rez les communications.' },
      { title: 'Perception des Loyers et Facturation', desc: 'G\u00e9n\u00e9rez des factures, enregistrez les paiements et suivez les arri\u00e9r\u00e9s.' },
      { title: 'Suivi de la Maintenance', desc: 'Enregistrez les demandes de maintenance et suivez la r\u00e9solution.' },
      { title: 'Rapports Financiers', desc: '\u00c9tats de revenus, versements aux propri\u00e9taires et suivi des d\u00e9penses.' },
      { title: 'Contr\u00f4le d\u2019Acc\u00e8s par R\u00f4le', desc: 'D\u00e9finissez les permissions pour le personnel, les propri\u00e9taires et les administrateurs.' },
    ],
    ctaTitle: 'Pr\u00eat \u00e0 Explorer ?',
    ctaDesc: 'La d\u00e9mo en direct est pr\u00e9charg\u00e9e avec des donn\u00e9es d\u2019exemple. Cliquez ci-dessous pour commencer imm\u00e9diatement.',
    ctaBtn: 'Ouvrir la D\u00e9mo',
    ctaNote: 'Aucune installation \u00b7 Aucune inscription \u00b7 Aucune carte de cr\u00e9dit',
    questionsTitle: 'Vous avez des Questions ?',
    questionsDesc: 'Notre \u00e9quipe est pr\u00eate \u00e0 vous aider \u00e0 comprendre comment Aqar peut fonctionner pour votre portefeuille.',
    whatsappBtn: 'Discuter sur WhatsApp',
  },
};

const t = content[lang];
---

<BaseLayout lang={lang} title={t.title} description={t.description} pageKey="demo">
  <Lightbox />

  <!-- Hero with laptop frame -->
  <section class="relative overflow-hidden min-h-[70vh] flex items-center">
    <Image
      src={heroBg}
      alt=""
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover"
      widths={[640, 1024, 1536, 2048]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/80 to-charcoal/40"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Text -->
        <div>
          <h1 class="animate-on-scroll font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
            {t.heroTitle}
          </h1>
          <p class="animate-on-scroll stagger-1 mt-6 text-lg sm:text-xl text-neutral-200 max-w-2xl leading-relaxed">
            {t.heroSubtitle}
          </p>
          <div class="animate-on-scroll stagger-2 mt-8">
            <a
              href="https://property.chwezi.co.za"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center rounded-lg bg-secondary-500 px-8 py-4 text-lg font-bold text-white shadow-lg hover:bg-secondary-600 transition-colors duration-200"
            >
              {t.ctaBtn}
              <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Laptop frame -->
        <div class="animate-on-scroll stagger-2 hidden lg:block">
          <div class="relative mx-auto max-w-md">
            <div class="rounded-t-xl bg-neutral-800 p-2 pb-0">
              <div class="flex items-center gap-1.5 px-2 pb-2">
                <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
              </div>
              <div
                class="screenshot-trigger relative overflow-hidden rounded-t-sm"
                @click={`$dispatch('open-lightbox', { src: '${screenshotLogin.src}', alt: '${t.loginAlt}', caption: '${t.loginCaption}' })`}
              >
                <Image
                  src={screenshotLogin}
                  alt={t.loginAlt}
                  class="w-full"
                  widths={[400, 600]}
                  sizes="400px"
                />
                <div class="expand-hint absolute inset-0 flex items-center justify-center bg-charcoal/30">
                  <span class="rounded-full bg-white/90 px-4 py-2 text-sm font-semibold text-charcoal shadow-lg">
                    {lang === 'en' ? 'Click to expand' : 'Cliquez pour agrandir'}
                  </span>
                </div>
              </div>
            </div>
            <div class="h-4 rounded-b-xl bg-neutral-700"></div>
            <div class="mx-auto h-2 w-1/3 rounded-b-lg bg-neutral-600"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Checklist -->
  <section class="bg-surface py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="animate-on-scroll font-display text-3xl sm:text-4xl font-extrabold text-charcoal text-center mb-12">
        {t.featuresTitle}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {t.features.map((feature, i) => (
          <div class={`animate-on-scroll stagger-${(i % 5) + 1} flex gap-4 rounded-xl bg-white border border-neutral-200 p-6 shadow-sm`}>
            <div class="shrink-0 mt-0.5">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary-100 text-primary-700">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="font-display text-base font-bold text-charcoal mb-1">{feature.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{feature.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Large CTA -->
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="animate-on-scroll font-display text-3xl sm:text-4xl font-extrabold text-white mb-6">
        {t.ctaTitle}
      </h2>
      <p class="animate-on-scroll stagger-1 text-lg text-neutral-300 leading-relaxed mb-8">
        {t.ctaDesc}
      </p>
      <div class="animate-on-scroll stagger-2">
        <a
          href="https://property.chwezi.co.za"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-xl bg-secondary-500 px-10 py-5 text-xl font-bold text-white shadow-xl hover:bg-secondary-600 transition-colors duration-200"
        >
          {t.ctaBtn}
          <svg class="ml-3 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <p class="mt-4 text-sm text-neutral-500">{t.ctaNote}</p>
      </div>
    </div>
  </section>

  <!-- Questions Section -->
  <section class="bg-surface py-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="animate-on-scroll font-display text-2xl sm:text-3xl font-bold text-charcoal mb-4">
        {t.questionsTitle}
      </h2>
      <p class="animate-on-scroll stagger-1 text-neutral-600 mb-6">{t.questionsDesc}</p>
      <div class="animate-on-scroll stagger-2">
        <a
          href="https://wa.me/256784464178"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-success-500 px-6 py-3 text-base font-bold text-white shadow-lg hover:bg-success-600 transition-colors duration-200"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          {t.whatsappBtn}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
