---
import type { Language } from '../../utils/i18n';
import { getLocalizedPath } from '../../utils/i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { Image } from 'astro:assets';

import heroBg from '../../assets/images/AQAR-PROPERTY-03.jpg';
import blogImg1 from '../../assets/images/AQAR-PROPERTY-10.jpg';
import blogImg2 from '../../assets/images/AQAR-PROPERTY-11.jpg';
import blogImg3 from '../../assets/images/AQAR-PROPERTY-12.jpg';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const content = {
  en: {
    title: 'Blog | Property Management Insights | AQAR',
    description: 'Expert property management tips, guides, and insights for landlords and property managers in East Africa.',
    heroTitle: 'Property Management Insights',
    heroSubtitle: 'Expert guides and tips for landlords and property managers.',
    readMore: 'Read More',
    posts: [
      {
        slug: 'choosing-property-management-company',
        title: 'How to Find a Property Management Company That Protects Your Returns',
        excerpt: 'Selecting the right property management company can make or break your real estate investment. Here is a three-level research approach to help you find the right partner.',
        date: '21 May 2025',
        image: blogImg1,
      },
      {
        slug: 'marketing-rental-properties',
        title: 'Marketing Your Rentals to Get Good Tenants',
        excerpt: 'Advertising is the critical link between vacant properties and prospective renters. Learn how to combine targeted and broad marketing approaches to find quality tenants.',
        date: '21 May 2025',
        image: blogImg2,
      },
      {
        slug: 'property-management-agreement',
        title: 'Setting Terms: The Property Management Agreement',
        excerpt: 'The success of property management hinges on one crucial document: the Property Management Agreement. Learn what essential clauses to include and how to protect your investment.',
        date: '22 May 2025',
        image: blogImg3,
      },
    ],
  },
  fr: {
    title: 'Blog | Conseils en Gestion Immobili\u00e8re | AQAR',
    description: 'Conseils, guides et analyses d\u2019experts en gestion immobili\u00e8re pour les propri\u00e9taires et gestionnaires en Afrique de l\u2019Est.',
    heroTitle: 'Conseils en Gestion Immobili\u00e8re',
    heroSubtitle: 'Guides et conseils d\u2019experts pour les propri\u00e9taires et gestionnaires immobiliers.',
    readMore: 'Lire la Suite',
    posts: [
      {
        slug: 'choisir-societe-gestion-immobiliere',
        title: 'Choisir la Bonne Soci\u00e9t\u00e9 de Gestion Immobili\u00e8re pour Vos Propri\u00e9t\u00e9s',
        excerpt: 'S\u00e9lectionner la bonne soci\u00e9t\u00e9 de gestion immobili\u00e8re peut d\u00e9terminer le succ\u00e8s ou l\u2019\u00e9chec de votre investissement immobilier. Voici une approche de recherche en trois niveaux.',
        date: '21 mai 2025',
        image: blogImg1,
      },
      {
        slug: 'commercialiser-proprietes-locatives',
        title: 'Commercialiser Vos Locations pour Trouver de Bons Locataires',
        excerpt: 'La publicit\u00e9 est le lien essentiel entre les propri\u00e9t\u00e9s vacantes et les locataires potentiels. D\u00e9couvrez comment combiner les approches marketing cibl\u00e9es et larges.',
        date: '21 mai 2025',
        image: blogImg2,
      },
      {
        slug: 'contrat-gestion-immobiliere',
        title: 'Fixer les Conditions : Le Contrat de Gestion Immobili\u00e8re',
        excerpt: 'Le succ\u00e8s de la gestion immobili\u00e8re repose enti\u00e8rement sur un document crucial : le contrat de gestion immobili\u00e8re. D\u00e9couvrez les clauses essentielles.',
        date: '22 mai 2025',
        image: blogImg3,
      },
    ],
  },
};

const t = content[lang];
---

<BaseLayout lang={lang} title={t.title} description={t.description} pageKey="blog">
  <!-- Hero -->
  <Hero lang={lang} title={t.heroTitle} subtitle={t.heroSubtitle} bgImage={heroBg} />

  <!-- Blog Cards -->
  <section class="bg-surface py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {t.posts.map((post, i) => (
          <article class={`animate-on-scroll stagger-${i + 1} group rounded-xl bg-white border border-neutral-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300`}>
            <a href={`/${lang}/blog/${post.slug}/`} class="block">
              <div class="aspect-[16/10] overflow-hidden">
                <Image
                  src={post.image}
                  alt={post.title}
                  class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
                  widths={[400, 600]}
                  sizes="(max-width: 768px) 90vw, (max-width: 1024px) 45vw, 30vw"
                />
              </div>
              <div class="p-6">
                <time class="text-xs font-semibold text-primary-600 uppercase tracking-wider">{post.date}</time>
                <h2 class="mt-2 font-display text-xl font-bold text-charcoal leading-snug group-hover:text-primary-700 transition-colors duration-200">
                  {post.title}
                </h2>
                <p class="mt-3 text-sm text-neutral-600 leading-relaxed line-clamp-3">
                  {post.excerpt}
                </p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:text-primary-800 transition-colors duration-200">
                  {t.readMore}
                  <svg class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
