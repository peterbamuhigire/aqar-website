---
import type { Language } from '../utils/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const content = {
  en: {
    headline: 'Ready to Simplify Property Management?',
    subtitle: 'Join landlords and property managers across East Africa who trust AQAR to streamline operations, boost collections, and grow their portfolios.',
    demo: 'Try Demo',
    whatsapp: 'WhatsApp Us',
  },
  fr: {
    headline: 'Pr\u00eat \u00e0 Simplifier la Gestion Immobili\u00e8re ?',
    subtitle: 'Rejoignez les propri\u00e9taires et gestionnaires immobiliers d\'Afrique de l\'Est qui font confiance \u00e0 AQAR pour optimiser leurs op\u00e9rations, am\u00e9liorer les recouvrements et d\u00e9velopper leurs portefeuilles.',
    demo: 'Essayer la D\u00e9mo',
    whatsapp: 'WhatsApp',
  },
};

const t = content[lang];
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-700 via-primary-600 to-primary-500 py-20">
  <!-- Decorative shapes -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-secondary-500"></div>
    <div class="absolute -bottom-16 -left-16 h-64 w-64 rounded-full bg-white"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="animate-on-scroll font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
      {t.headline}
    </h2>
    <p class="animate-on-scroll stagger-1 mt-6 text-lg text-primary-100 max-w-2xl mx-auto leading-relaxed">
      {t.subtitle}
    </p>
    <div class="animate-on-scroll stagger-2 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://property.chwezi.co.za"
        target="_blank"
        rel="noopener noreferrer"
        class="btn inline-flex items-center rounded-lg bg-white px-8 py-4 text-base font-bold text-primary-700 shadow-lg hover:bg-neutral-100 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2"
      >
        {t.demo}
      </a>
      <a
        href="https://wa.me/256784464178"
        target="_blank"
        rel="noopener noreferrer"
        class="btn inline-flex items-center rounded-lg bg-secondary-500 px-8 py-4 text-base font-bold text-white shadow-lg hover:bg-secondary-600 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2"
      >
        {t.whatsapp}
      </a>
    </div>
  </div>
</section>
